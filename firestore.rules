rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isUserAllowed(email) {
      return exists(/databases/$(database)/documents/allowed_users/$(email));
    }

    match /{document=**} {
      allow read, write: if request.auth != null && isUserAllowed(request.auth.token.email);
    }
  }
}