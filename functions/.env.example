# ───────────────────────────────────────────────────────────
# BitGo backend configuration (functions/.env)
# Copy to functions/.env for local emulator development.
# In production set these via `firebase functions:config` / env.
# ───────────────────────────────────────────────────────────

# === BitGo ===
BITGO_ACCESS_TOKEN=v2x...           # BitGo API access token
BITGO_ENV=test                       # 'test' (app.bitgo-test.com) or 'prod'
BITGO_WALLET_ID=                     # Go Account / custodial wallet id
BITGO_ENTERPRISE_ID=                 # KSI enterprise id
BITGO_WEBHOOK_SECRET=                # Shared secret for HMAC webhook verification

# Use the following curl command along with your access token and enterpise id.
# you must create the webhook in your wallet then
# make sure your access token has your current ip address allowed
# curl -X POST "https://app.bitgo-test.com/api/v2/webhook/secret" \
#   -H "Authorization: Bearer <YOUR_ACCESS_TOKEN>" \
#   -H "Content-Type: application/json" \
#   -d '{
#     "enterpriseId": "<YOUR_ENTERPRISE_ID>"
#   }'

BITGO_EXPRESS_URL=                   # Optional local BitGo Express signing server

# Coin ticker for the deposit asset (BitGo statics naming).
#   testnet USDC on Holesky → hteth:tusdc  (base coin: hteth)
#   mainnet USDC            → eth:usdcv     (base coin: eth)
BITGO_COIN=hteth:tusdc

# === Ethereum RPC (mempool monitor) ===
# Websocket endpoint is REQUIRED for real-time mempool detection.
ETH_WS_RPC_URL=wss://eth-holesky.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ETH_HTTP_RPC_URL=https://eth-holesky.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
USDC_TOKEN_ADDRESS=                  # USDC ERC-20 contract on the target network
DEPOSIT_CONFIRMATIONS=1

# === Cashier business rules ===
CHIPS_PER_USDC=1
INTENT_TTL_MINUTES=30
MIN_DEPOSIT_USDC=1
MAX_DEPOSIT_USDC=100000
COMPLIANCE_ENFORCED=true
