{
  "hosting": {
    "source": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "functions/**"
    ],
    "frameworksBackend": {
      "region": "us-west1"
    }
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "cashier",
      "runtime": "nodejs22",
      "predeploy": ["npm --prefix \"$RESOURCE_DIR\" run build"],
      "ignore": [
        "node_modules",
        ".git",
        "*.log"
      ]
    }
  ]
}
