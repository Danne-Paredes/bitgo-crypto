# ───────────────────────────────────────────────────────────
# Frontend configuration (Vite) — BitGo deposit-address flow
# The frontend no longer talks to the chain directly. It only needs
# display metadata and the cashier backend URL. BitGo secrets live in
# functions/.env (server-side only).
# ───────────────────────────────────────────────────────────

# === Network display metadata ===
VITE_CHAIN_NAME=Ethereum Holesky
VITE_BLOCK_EXPLORER_URL=https://holesky.etherscan.io
VITE_ASSET_SYMBOL=USDC

# === Chip Exchange Rate ===
VITE_CHIPS_PER_USDC=1

# === Status polling cadence (ms) ===
VITE_STATUS_POLL_INTERVAL_MS=4000

# === Backend API (Firebase Cloud Functions) ===
# Local dev:  http://localhost:5001/kv-crypto-app/us-central1/cashier
# Production: https://us-central1-kv-crypto-app.cloudfunctions.net/cashier
VITE_API_BASE_URL=https://us-central1-kv-crypto-app.cloudfunctions.net/cashier
