# ───────────────────────────────────────────────────────────
# Frontend configuration (Vite) — BitGo deposit-address flow
# with WalletConnect integration
# ───────────────────────────────────────────────────────────

# === Network (Hoodi testnet) ===
VITE_CHAIN_NAME=Ethereum Hoodi
VITE_CHAIN_ID=560048
VITE_RPC_URL=https://eth-hoodi.g.alchemy.com/v2/YOUR_KEY
VITE_BLOCK_EXPLORER_URL=https://hoodi.etherscan.io
VITE_BLOCK_CONFIRMATIONS=1

# === ERC-20 USDC on Hoodi ===
VITE_USDC_TOKEN_ADDRESS=0x76c57d19bd3529dadf4bb66e75f0808bc8264a5e

# === Asset display ===
VITE_ASSET_SYMBOL=USDC
VITE_CHIPS_PER_USDC=1

# === WalletConnect ===
VITE_WALLETCONNECT_PROJECT_ID=YOUR_PROJECT_ID

# === Backend API (Firebase Cloud Functions) ===
# Local dev:  http://localhost:5001/kv-crypto-app/us-central1/cashier
# Production: https://us-central1-kv-crypto-app.cloudfunctions.net/cashier
VITE_API_BASE_URL=https://us-central1-kv-crypto-app.cloudfunctions.net/cashier
